RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALERT_FROM_EMAIL=alerts@yourdomain.com

# Set to 'true' during migration to auto-provision unknown API keys
DISCOVERY_MODE=false

# Dashboard auth (email OTP)
AUTH_SECRET=replace-with-32+ random bytes
AUTH_ALLOWED_EMAILS=matt@redleg.dev,you@yourdomain.com
OTP_EXPIRY_MINUTES=10
EMAIL_FROM=Log Cannon <logs@redleg.dev>
# EMAIL_TRANSPORT=smtp (default; sends to inbucket service in compose)
# In production, set EMAIL_TRANSPORT=resend so OTPs go through Resend.
# EMAIL_TRANSPORT=resend

# Local dev only — activates the inbucket service (gated by profile).
# Leave unset / blank in production so inbucket doesn't start there.
COMPOSE_PROFILES=dev

R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=log-cannon-backups

# Day of week for full backups (0=Sunday, 1=Monday, ..., 6=Saturday)
BACKUP_FULL_SCHEDULE=0