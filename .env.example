# ─── Dashboard auth (email OTP) ──────────────────────────────────────────────
AUTH_SECRET=replace-with-32+-random-bytes        # openssl rand -hex 32
AUTH_ALLOWED_EMAILS=you@example.com,teammate@example.com
OTP_EXPIRY_MINUTES=10
EMAIL_FROM=Log Cannon <logs@example.com>

# Email transport for OTPs: "smtp" (default) or "saasmail".
# - smtp:     local dev sends to the bundled Inbucket service; in prod point
#             SMTP_HOST/SMTP_PORT at any provider (Resend, Mailgun, SES, Postmark…).
# - saasmail: HTTP email API (POST {SAASMAIL_API_URL}/api/send, multipart "payload").
# EMAIL_TRANSPORT=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587

# ─── HTTP email API (alert emails always use this; OTPs use it when EMAIL_TRANSPORT=saasmail) ─
SAASMAIL_API_KEY=your-email-api-key
SAASMAIL_API_URL=https://mail.example.com
ALERT_FROM_EMAIL=alerts@example.com

# ─── Access ──────────────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token
DASHBOARD_URL=https://logs.example.com

# ─── Edge ingestion (queue consumer → Cloudflare Queue) ──────────────────────
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_QUEUE_ID=your-queue-id
CF_API_TOKEN=your-api-token-with-queue-read

# Set to 'true' during migration to auto-provision unknown API keys.
DISCOVERY_MODE=false

# ─── Local dev only ──────────────────────────────────────────────────────────
# Activates the Inbucket mailbox service (gated by profile). Leave unset in prod.
COMPOSE_PROFILES=dev

# ─── Offsite backups (Cloudflare R2) ─────────────────────────────────────────
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=log-cannon-backups

# Day of week for full backups (0=Sunday, 1=Monday, ..., 6=Saturday).
BACKUP_FULL_SCHEDULE=0
